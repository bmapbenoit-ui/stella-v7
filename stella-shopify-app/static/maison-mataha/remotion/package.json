{
  "name": "maison-mataha-remotion",
  "version": "0.1.0",
  "description": "Remotion compositions for Maison Mataha TikTok variations (Veo 3 + ElevenLabs + Whisper)",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts",
    "render:varC": "remotion render src/index.ts EscapadeGourmande_VarC out/escapade-gourmande-varC.mp4 --concurrency=4 --pixel-format=yuv420p",
    "veo:generate": "tsx scripts/generate-veo.ts",
    "voice:generate": "tsx scripts/generate-voiceover.ts",
    "stock:fetch": "tsx scripts/fetch-stock.ts",
    "all": "npm run veo:generate && npm run voice:generate && npm run render:varC"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.51.0",
    "@remotion/bundler": "^4.0.350",
    "@remotion/captions": "^4.0.350",
    "@remotion/cli": "^4.0.350",
    "@remotion/install-whisper-cpp": "^4.0.350",
    "@remotion/media-utils": "^4.0.350",
    "@remotion/renderer": "^4.0.350",
    "@remotion/transitions": "^4.0.350",
    "dotenv": "^16.4.7",
    "@elevenlabs/elevenlabs-js": "^2.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.350",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
