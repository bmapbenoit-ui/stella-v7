# ─── ElevenLabs (voix off française murmurée) ──────────────────────────────
ELEVENLABS_API_KEY=
# Voix recommandée pour Maison Mataha : Charlotte (FR, intime)
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa
# Modèle multilingue v2 (meilleur sur le français)
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Google Cloud / Vertex AI (génération vidéo Veo 3) ─────────────────────
GOOGLE_CLOUD_PROJECT=
# us-central1 ou europe-west4 (latence + dispo Veo 3)
GOOGLE_CLOUD_LOCATION=us-central1
# Chemin vers la service account JSON (gitignored)
GOOGLE_APPLICATION_CREDENTIALS=./vertex-credentials.json
# Modèle Veo (3.1 = dernière stable avec referenceImages + audio synchronisé)
VEO_MODEL=veo-3.1-generate-preview

# ─── Pexels (B-roll de secours / références) ───────────────────────────────
# Optionnel — gratuit, sign up: https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── Suno via KIE (musique de fond générée) ────────────────────────────────
# Optionnel — sinon on utilise une nappe générée par notre Web Audio
KIE_API_KEY=
